# Grafana dashboard generation — environment-specific variables
# Copy this file to grafana.env.<env> (e.g. grafana.env.tds) and fill in the values.
# The generated dashboard will be written to local/<env>/firecrest-ui-observability.json
# (gitignored — do not commit generated files).
#
# Generate: ./generate-dashboard.sh grafana.env.<env>

# UID of the Elasticsearch datasource in Grafana for this environment.
# Find it in Grafana → Connections → Data sources → <your datasource> → URL (uid in the address bar).
DATASOURCE_UID=your-elasticsearch-datasource-uid

# Display label shown in the dashboard title (e.g. TDS, Prod).
ENV_TITLE=MyEnvironment

# Unique Grafana dashboard UID. Must be unique per environment to allow both
# dashboards to coexist in the same Grafana instance.
# Convention: firecrest-ui-observability-<env-slug> (e.g. firecrest-ui-observability-tds)
DASHBOARD_UID=firecrest-ui-observability-myenvironment
